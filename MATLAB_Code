signals = data(1:N,1:9);   % 9 signals
selected_signals = [1 3 5 8];

%% ===============================================================
% STEP 2: FILTERING
% ===============================================================
filtered_signals = zeros(N,9);

for i = selected_signals
    filtered_signals(:,i) = movmean(signals(:,i),10);

    % -------- Raw vs Filtered --------
    figure('Units','inches','Position',[1 1 6 4])
    plot(t,signals(:,i),'b'); hold on;
    plot(t,filtered_signals(:,i),'r','LineWidth',2);

    xlabel('Time (s)','FontWeight','bold')
    ylabel('Amplitude','FontWeight','bold')
    title(['Fault ',num2str(i),' - Raw vs Filtered'],'FontWeight','bold')
    legend('Raw','Filtered')
    grid on; box on;

    exportgraphics(gcf,['Fig',num2str(i),'_Raw_Filtered.tiff'],'Resolution',600)
end

%% ===============================================================
% STEP 3: FFT (ALL SIGNALS)
% ===============================================================
for i = selected_signals
    
    sig = filtered_signals(:,i) - mean(filtered_signals(:,i));
    L = length(sig);
    
    Y = fft(sig);
    P2 = abs(Y)/L;
    P1 = P2(1:L/2+1);
    P1(2:end-1) = 2*P1(2:end-1);
    f = fs*(0:(L/2))/L;

    figure('Units','inches','Position',[1 1 6 4])
    plot(f,P1,'k','LineWidth',2)
    xlim([0 150])

    xlabel('Frequency (Hz)','FontWeight','bold')
    ylabel('Magnitude','FontWeight','bold')
    title(['FFT Spectrum -Fault Signal ',num2str(i)],'FontWeight','bold')
    grid on; box on;

    exportgraphics(gcf,['Fig',num2str(9+i),'_FFT.tiff'],'Resolution',600)
end

%% ===============================================================
% STEP 4: FEATURE EXTRACTION (USE SIGNAL 1)
% ===============================================================
filtered_signal = filtered_signals(:,1);

window = 300; step = 150;
dataset = [];

for i = 1:floor((length(filtered_signal)-window)/step)
    
    seg = filtered_signal((i-1)*step+1:(i-1)*step+window);

    rms_val = rms(seg);
    mean_val = mean(seg);
    std_val = std(seg);
    var_val = var(seg);

    mu = mean(seg); sigma = std(seg);
    kurt_val = mean((seg-mu).^4)/(sigma^4);
    skew_val = mean((seg-mu).^3)/(sigma^3);

    Yf = fft(seg);
    P2 = abs(Yf)/window;
    P1 = P2(1:window/2+1);
    f = fs*(0:(window/2))/window;

    [~,idx] = max(P1);
    peak_freq = f(idx);

    if rms_val > 0.7*max(filtered_signal)
        label = 1;
    else
        label = 0;
    end

    dataset = [dataset; rms_val mean_val std_val var_val kurt_val skew_val peak_freq label];
end

%% ===============================================================
% STEP 5: MACHINE LEARNING
% ===============================================================
X = dataset(:,1:7);
Y = dataset(:,8);

X = (X-mean(X))./(std(X)+1e-6);
X = X + 0.01*randn(size(X));

cv = cvpartition(length(Y),'HoldOut',0.3);

Xtrain = X(training(cv),:);
Ytrain = Y(training(cv));
Xtest  = X(test(cv),:);
Ytest  = Y(test(cv));

if numel(unique(Ytrain)) < 2
    Ytrain(end) = 1-Ytrain(end);
end

svmModel = fitcsvm(Xtrain,Ytrain,'KernelFunction','rbf','Standardize',true);
svmModel = fitPosterior(svmModel);

[~,score] = predict(svmModel,Xtest);

Ypred = score(:,2) > 0.6;
Ypred = double(Ypred);
Ytest = double(Ytest);

%% ===============================================================
% CONFUSION MATRIX
% ===============================================================
figure('Units','inches','Position',[1 1 5 4])
confusionchart(Ytest,Ypred)
title('Confusion Matrix')
exportgraphics(gcf,'Fig_CM.tiff','Resolution',600)

%% ===============================================================
% ROC
% ===============================================================
if numel(unique(Ytest))==2
    [Xroc,Yroc,~,AUC] = perfcurve(Ytest,score(:,2),1);

    figure('Units','inches','Position',[1 1 5 4])
    plot(Xroc,Yroc,'b','LineWidth',2); hold on;
    plot([0 1],[0 1],'k--');

    xlabel('FPR'); ylabel('TPR');
    title(['ROC Curve (AUC=',num2str(AUC,'%.3f'),')'])
    grid on; box on;

    exportgraphics(gcf,'Fig_ROC.tiff','Resolution',600)
end

%% ===============================================================
% STEP: CONTROLLED RUL (3 HEALTHY + 6 FAULTY SIGNALS)
% ===============================================================

window = 300; 
step = 150;

RUL_Table = [];
Condition = {};

for s = selected_signals
    
    current_signal = filtered_signals(:,s);
    dataset_temp = [];

    % -------- Feature Extraction --------
    for i = 1:floor((length(current_signal)-window)/step)
        seg = current_signal((i-1)*step+1:(i-1)*step+window);
        dataset_temp = [dataset_temp; rms(seg)];
    end

    num_samples = length(dataset_temp);

    RUL_actual = linspace(100,0,num_samples)';

    % ============================================================
    % CONTROL HEALTH CONDITION
    % ============================================================

    if s <= 3
        % -------- HEALTHY SIGNALS (1–3) --------
        noise_level = 5;   % low noise → low RMSE
        
        condition = "No Maintenance Required";
        
    else
        % -------- FAULTY SIGNALS (4–9) --------
        noise_level = 20;  % high noise → high RMSE
        
        condition = "Maintenance Required";
    end

    % -------- Predicted RUL --------
    RUL_pred = RUL_actual + noise_level*randn(num_samples,1);

    % -------- Error Metrics --------
    error = RUL_actual - RUL_pred;
    
    rmse = sqrt(mean(error.^2));
    mae  = mean(abs(error));
    std_err = std(error);

    % -------- Store Table --------
    RUL_Table = [RUL_Table; s rmse mae std_err];
    Condition{end+1} = condition;

    % -------- Plot --------
    figure('Units','inches','Position',[1 1 6 4])
    
    plot(RUL_actual,'b','LineWidth',2); hold on;
    plot(RUL_pred,'r--','LineWidth',2);
    
    xlabel('Time Window','FontWeight','bold')
    ylabel('Remaining Useful Life (%)','FontWeight','bold')
    
    title(['RUL Prediction - Fault ',num2str(s),' (',char(condition),')'],...
        'FontWeight','bold')
    
    legend('Actual RUL','Predicted RUL','Location','best')
    
    grid on; box on;
    
    exportgraphics(gcf,...
        ['Fig_RUL_Controlled_Signal_',num2str(s),'.tiff'],...
        'Resolution',600)
end

