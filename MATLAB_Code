            svm_accuracy, current_RUL, health_score, status_text);

        % ✅ RETRY LOGIC
        success = false;
        attempts = 0;

        while ~success && attempts < 3
            try
                thingSpeakWrite(channelIDs(idx), ...
                    [svm_accuracy current_RUL health_score fault_status], ...
                    'WriteKey', writeKeys{idx}, ...
                    'Timeout', 20);

                success = true;
                disp("Data sent successfully");

            catch
                attempts = attempts + 1;
                disp("Retrying...");
                pause(5);
            end
        end

        pause(16); % ThingSpeak limit
    end

end

